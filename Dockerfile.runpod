FROM runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

WORKDIR /workspace

# Install uv
RUN pip install uv

# Copy project files
COPY pyproject.toml uv.lock* ./
COPY finetune/ finetune/
COPY data/dataset/ data/dataset/

# Install train dependencies
RUN uv sync --extra train --no-dev

# Copy the entrypoint
COPY scripts/runpod_train.sh /workspace/runpod_train.sh
RUN chmod +x /workspace/runpod_train.sh

CMD ["/workspace/runpod_train.sh"]
